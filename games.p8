pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
g=0
mi=1
px=56 py=56
bx=64 by=64
bdx=1 bdy=1
s1=0 s2=0
sn={}
sdx=4 sdy=0
fx=0 fy=0
st=0
ss=0
fv=0 fby=64
fpx={} fpt={} fps=0 fpg=0 fsc={}
function _init()
 g=0 mi=1
end
function _update()
 if g==0 then
  if btnp(2) then mi=max(mi-1,1) end
  if btnp(3) then mi=min(mi+1,3) end
  if btnp(4) or btnp(5) then
   if mi==1 then init_pong()
   elseif mi==2 then init_snake()
   else init_flappy() end
  end
 elseif g==1 then update_pong()
 elseif g==2 then update_snake()
 else update_flappy() end
end
function _draw()
 cls()
 if g==0 then draw_menu()
 elseif g==1 then draw_pong()
 elseif g==2 then draw_snake()
 else draw_flappy() end
end
function draw_menu()
 print("pico games",44,16,7)
 local ops={"1. pong","2. snake","3. flappy"}
 for i=1,3 do
  local c=7
  if mi==i then c=8 print(">",38,36+i*12,c) end
  print(ops[i],50,36+i*12,c)
 end
 print("\145\143 to select",36,84,7)
 print("\136\139 to move",36,94,7)
end
function init_pong()
 g=1 px=56 py=56 bx=64 by=64
 bdx=1 bdy=rnd(2)-1 s1=0 s2=0
end
function update_pong()
 if btn(2) then px=max(px-2,0) end
 if btn(3) then px=min(px+2,96) end
 if by>py+8 then py+=1 end
 if by<py+8 then py-=1 end
 py=mid(py,0,96)
 bx+=bdx by+=bdy
 if by<=0 or by>=128 then bdy=-bdy end
 if bx<=6 and by>=px and by<=px+32 then bdx=-bdx bdx+=0.2 end
 if bx>=118 and by>=py and by<=py+32 then bdx=-bdx bdx-=0.2 end
 if bx<0 then s2+=1 reset_ball() end
 if bx>128 then s1+=1 reset_ball() end
 if s1>=3 or s2>=3 then g=0 end
end
function reset_ball()
 bx=64 by=64
 bdx=sgn(rnd(2)-1) or 1
 if bdx==0 then bdx=1 end
 bdy=rnd(2)-1
end
function draw_pong()
 rectfill(2,px,6,px+32,7)
 rectfill(122,py,126,py+32,7)
 circfill(bx,by,2,7)
 print(s1.." - "..s2,52,2,7)
 for i=0,128,8 do pset(64,i,7) end
 for i=0,128,4 do pset(i,0,1) pset(i,127,1) end
end
function init_snake()
 g=2
 sn={{x=64,y=64},{x=60,y=64},{x=56,y=64}}
 sdx=4 sdy=0 ss=0 st=0
 spawn_food()
end
function spawn_food()
 local ok=false
 while not ok do
  fx=flr(rnd(30))*4+2
  fy=flr(rnd(28))*4+6
  ok=true
  for s in all(sn) do
   if s.x==fx and s.y==fy then ok=false end
  end
 end
end
function update_snake()
 if ss==1 then
  if btnp(4) or btnp(5) then g=0 end
  return
 end
 if btnp(0) and sdy==0 then sdx=-4 sdy=0 end
 if btnp(1) and sdy==0 then sdx=4 sdy=0 end
 if btnp(2) and sdx==0 then sdx=0 sdy=-4 end
 if btnp(3) and sdx==0 then sdx=0 sdy=4 end
 st+=1
 if st>=6 then
  st=0
  local nx=sn[1].x+sdx
  local ny=sn[1].y+sdy
  if nx<0 or nx>124 or ny<4 or ny>124 then ss=1 return end
  for s in all(sn) do
   if s.x==nx and s.y==ny then ss=1 return end
  end
  add(sn,{x=nx,y=ny},1)
  if nx==fx and ny==fy then
   spawn_food()
  else
   deli(sn,#sn)
  end
 end
end
function draw_snake()
 for s in all(sn) do
  rectfill(s.x,s.y,s.x+4,s.y+4,11)
 end
 rectfill(fx,fy,fx+4,fy+4,8)
 print(#sn-3,4,4,7)
 if ss==1 then
  rectfill(24,44,104,80,0)
  print("game over!",40,54,7)
  print("\145\143 for menu",32,70,7)
 end
end
function init_flappy()
 g=3
 fby=64 fv=0
 fpx={} fpt={} fsc={}
 fps=0 fpg=0
 for i=0,3 do
  new_pipe(140+i*45)
 end
end
function new_pipe(x)
 add(fpx,x)
 add(fpt,16+flr(rnd(64)))
end
function update_flappy()
 if fpg==1 then
  if btnp(4) or btnp(5) then g=0 end
  return
 end fv+=0.4 fby+=fv
 if btnp(4) or btnp(5) then fv=-3 end
 if fby<0 or fby>124 then fpg=1 return end
 for i=#fpx,1,-1 do
  fpx[i]-=1
  if fpx[i]<-12 then
   deli(fpx,i) deli(fpt,i)
   new_pipe(fpx[#fpx]+50)
  end
 end
 for i=1,#fpx do
  if fpx[i]>-8 and fpx[i]<20 then
   local cp=fpx[i]
   if cp<20 and cp>12 then
    if fby<fpt[i] or fby+8>fpt[i]+28 then
     fpg=1 return
    end
   end
  end
  if fpx[i]<16 and fpx[i]>12 and not fsc[i] then
   fps+=1 fsc[i]=true
  end
 end
end
function draw_flappy()
 for i=1,#fpx do
  rectfill(fpx[i],0,fpx[i]+8,fpt[i],11)
  rectfill(fpx[i],fpt[i]+28,fpx[i]+8,128,11)
 end
 circfill(18,fby+4,5,8)
 circfill(18,fby+4,3,7)
 print("score: "..fps,4,4,7)
 if fpg==1 then
  rectfill(24,44,104,80,0)
  print("game over!",40,54,7)
  print("\145\143 for menu",32,70,7)
 end
end
