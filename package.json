{
  "name": "qdcli-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "ci": "vp check && vp test && vp run typecheck:tsgo && vp run -r build",
    "dev:view": "vp run @qdcli/viewer#dev",
    "format": "vp fmt --write .",
    "format:check": "vp fmt --check .",
    "lint": "vp lint",
    "pack": "vp pm pack --filter qdcli -- --dry-run",
    "test": "vp test",
    "typecheck": "vp check",
    "typecheck:tsgo": "vp exec tsgo --noEmit -p tsconfig.json && vp run --filter ./packages/* --filter ./apps/* typecheck:tsgo"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260624.1",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=11.1.0"
  },
  "packageManager": "pnpm@11.1.0"
}
