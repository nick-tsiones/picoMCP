{
  "name": "qdcli",
  "version": "0.1.0",
  "description": "Quick DAG CLI for agent-readable project orchestration",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cat-cave/qdcli.git"
  },
  "bin": {
    "qd": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "scripts": {
    "build": "vp pack src/index.ts --format esm --dts --banner.js \"#!/usr/bin/env node\"",
    "typecheck": "vp exec tsgo --noEmit -p tsconfig.json",
    "typecheck:tsgo": "vp exec tsgo --noEmit -p tsconfig.json",
    "test": "vp test run"
  },
  "dependencies": {
    "@qdcli/core": "workspace:*"
  }
}
