{
  "name": "@cat-cave/qdcli",
  "version": "0.1.14",
  "description": "Quick DAG CLI for agent-readable project orchestration",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cat-cave/qdcli.git",
    "directory": "packages/cli"
  },
  "bin": {
    "qd": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "pnpm run build",
    "build": "node ../../scripts/build-cli-package.mjs",
    "typecheck": "vp exec tsgo --noEmit -p tsconfig.json",
    "typecheck:tsgo": "vp exec tsgo --noEmit -p tsconfig.json",
    "test": "vp test run"
  },
  "dependencies": {
    "@cat-cave/qdcli-core": "workspace:*"
  },
  "engines": {
    "node": ">=24.14.0"
  }
}
